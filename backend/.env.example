# ──────────────────────────────────────────────────────────────────
# Director Desk — Environment Configuration
# ──────────────────────────────────────────────────────────────────
#
# AI PROVIDER: Alibaba Cloud — Qwen (通义千问)
# All AI features in Director Desk are powered exclusively by
# Alibaba Cloud's Qwen models via the DashScope API.
#
# API Base URL (International — OpenAI-compatible endpoint):
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#
# Get your API key at: https://dashscope.console.aliyun.com/
# ──────────────────────────────────────────────────────────────────

# ── Alibaba Cloud / Qwen DashScope ────────────────────────────────
QWEN_API_KEY=your-dashscope-api-key-here
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen model selections (see https://www.alibabacloud.com/help/en/model-studio/)
QWEN_MODEL=qwen-plus                # Primary language model (text generation & agents)
QWEN_VISION_MODEL=qwen-vl-plus      # Vision/image understanding model
QWEN_IMAGE_MODEL=wan2.6-t2i         # Text-to-image generation (Wan 2.6)

# ── App ───────────────────────────────────────────────────────────
APP_NAME=Director Desk
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173/

# ── Authentication ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key

# ── Email (Resend) ────────────────────────────────────────────────
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=your-resend-api-key-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
